# =============================================================================
# NextOlymp Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
# Do NOT commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=                        # Use a strong, randomly generated password
DB_NAME=nextolympservice
# DB_HOST and DB_PORT are set in docker-compose.prod.yml (postgres:5432)

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                     # Leave empty if Redis is not exposed externally; set a password if it is

# -----------------------------------------------------------------------------
# JWT Secrets (User-facing auth)
# Generate with: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=                  # REQUIRED -- generate a strong random string
JWT_REFRESH_SECRET=                 # REQUIRED -- generate a different strong random string
JWT_ACCESS_EXPIRY_HOURS=1           # Access token lifetime in hours
JWT_REFRESH_EXPIRY_HOURS=168        # Refresh token lifetime in hours (168 = 7 days)

# -----------------------------------------------------------------------------
# JWT Secrets (Admin/Superadmin panel)
# Generate with: openssl rand -hex 64
# -----------------------------------------------------------------------------
PANEL_JWT_ACCESS_SECRET=            # REQUIRED -- generate a strong random string
PANEL_JWT_REFRESH_SECRET=           # REQUIRED -- generate a different strong random string
PANEL_JWT_ACCESS_EXPIRY_HOURS=8     # Panel access token lifetime
PANEL_JWT_REFRESH_EXPIRY_HOURS=168  # Panel refresh token lifetime

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=                   # Google OAuth 2.0 Client ID from console.cloud.google.com

# -----------------------------------------------------------------------------
# Anthropic (AI analysis)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=                  # API key from console.anthropic.com

# -----------------------------------------------------------------------------
# Payme Payment Gateway
# -----------------------------------------------------------------------------
PAYME_MERCHANT_ID=                  # Merchant ID from Payme dashboard
PAYME_KEY=                          # Production key from Payme
PAYME_TEST_KEY=                     # Test key from Payme (used when PAYME_TEST_MODE=true)
PAYME_TEST_MODE=false               # Set to "true" only for staging/testing

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                 # Bot token from @BotFather
TELEGRAM_BOT_USERNAME=              # Bot username without the @ prefix

# -----------------------------------------------------------------------------
# Application Config
# -----------------------------------------------------------------------------
APP_BASE_URL=https://nextolymp.uz   # Public-facing base URL (used for uploads, callbacks, etc.)
CORS_ALLOWED_ORIGINS=https://nextolymp.uz  # Comma-separated list of allowed CORS origins
MAX_UPLOAD_SIZE_MB=10               # Maximum file upload size in megabytes

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://nextolymp.uz/api/v1  # API URL used by the Next.js frontend

# -----------------------------------------------------------------------------
# SSL Certificates
# -----------------------------------------------------------------------------
SSL_CERT_DIR=./ssl                  # Directory containing fullchain.pem and privkey.pem
                                    # For Let's Encrypt: /etc/letsencrypt/live/nextolymp.uz
